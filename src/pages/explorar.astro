---
import Layout from "../layouts/Layout.astro";
import NewPageWrapper from "../components/home-page/PageWrapperfil";

// Tipos D1
type PersonajeRow = {
  id_personaje: number | string;
  nombre_personaje: string;
  img_personaje: string | null;
  id_universo?: number | null;
  productsCount?: number; // viene del query (COUNT)
};

type ProductoRow = {
  id_producto: number | string;
  nombre_producto: string;
  subtitulo?: string | null;
  descripcion?: string | null;
  img_producto?: string | null;
  unidades?: number | null;
  precio?: number | null;
  descuento?: number | null;
  id_proveedor?: number | null;
  id_universo?: number | null;
  id_personaje?: number | null;
  fecha_creacion?: string | null;
  fecha_modifica?: string | null;
};

// Helper slug
function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

// D1 binding
const db = Astro.locals.runtime.env.DB as any;

let personajes: PersonajeRow[] = [];
let productos: ProductoRow[] = [];

if (!db) {
  console.warn("[explorar] DB binding no disponible. Render vacío pero sin crashear.");
} else {
  // Personajes + conteo de productos
  const personajesRes = await db
    .prepare(`
      SELECT
        p.id_personaje,
        p.nombre_personaje,
        p.img_personaje,
        p.id_universo,
        COUNT(pr.id_producto) AS productsCount
      FROM personajes p
      LEFT JOIN productos pr
        ON pr.id_personaje = p.id_personaje
      GROUP BY p.id_personaje
      ORDER BY p.nombre_personaje ASC
    `)
    .all();

  personajes = (personajesRes?.results || []) as PersonajeRow[];

  // Productos
  const productosRes = await db
    .prepare(`
      SELECT
        id_producto,
        nombre_producto,
        subtitulo,
        descripcion,
        img_producto,
        unidades,
        precio,
        descuento,
        id_proveedor,
        id_universo,
        id_personaje,
        fecha_creacion,
        fecha_modifica
      FROM productos
    `)
    .all();

  productos = (productosRes?.results || []) as ProductoRow[];
}

// categories: 1 card por personaje (formato compatible con tu UI)
const categories = personajes.map((p) => ({
  meta: {
    title: p.nombre_personaje,
    slug: slugify(p.nombre_personaje),
    // D1 -> { url }
    gallery: p.img_personaje ? [{ url: p.img_personaje }] : [],
  },
  productsCount: Number((p as any).productsCount || 0),
}));

// mapa id_personaje -> slug (para filtrar productos por personaje)
const personajeSlugMap = new Map<string, string>();
personajes.forEach((p) => {
  personajeSlugMap.set(String(p.id_personaje), slugify(p.nombre_personaje));
});

// productsLite: forma “BCMS-like” mínima para tu ProductCard/HomeProducts
const productsLite = productos.map((pr) => {
  const personajeSlug = personajeSlugMap.get(String(pr.id_personaje)) || "";

  return {
    _id: String(pr.id_producto),
    slug: slugify(String(pr.nombre_producto ?? `p-${pr.id_producto}`)),
    title: pr.nombre_producto ?? `Producto ${pr.id_producto}`,

    // Precio
    price: pr.precio ?? 0,

    // Para el filtro (D1)
    personajeSlug,

    // Estas props las usa tu ProductCard aunque sean “fake”
    gender: { title: "Personaje", slug: personajeSlug },
    categories: [],
    brand: { title: "Dino Cat 3D", slug: "dino-cat" },
    sizes: [],

    // Imagen (D1)
    cover: pr.img_producto ? ({ url: pr.img_producto } as any) : null,
    gallery: pr.img_producto ? [{ url: pr.img_producto }] : [],

    // extras
    date: Date.now(),
  };
});

// filtros
const filters = {
  categories: [],
  personajes: categories.map((c) => c.meta), // [{title,slug,...}]
};

// meta simple (sin BCMS)
const meta = { title: "Explorar Personajes" };
---

<Layout title="Explorar Personajes | 3D Shop">
  <NewPageWrapper
    client:load
    meta={meta}
    categories={categories as any}
    products={productsLite as any}
    filters={filters}
    bcms={{} as any}
  />
</Layout>