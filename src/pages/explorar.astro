---
import Layout from "../layouts/Layout.astro";
import NewPageWrapper from "../components/home-page/PageWrapperfil";

type PersonajeRow = {
  id_personaje: number | string;
  nombre_personaje: string;
  id_universo?: number | null;
  productsCount?: number;
  gallery?: string;
};

type UniversoRow = {
  id_universo: number | string;
  nombre_universo: string;
  img_universo?: string | null;
};

type EtiquetaRow = {
  id_etiqueta: string;
  nombre_etiqueta: string;
};

type CategoryCard = {
  meta: {
    id_personaje?: number | string;
    title: string;
    slug: string;
    gallery: { url: string }[];
  };
  productsCount: number;
};

type UniverseCard = {
  id: string;
  title: string;
  imageUrl: string | null;
};

type OriginItem = {
  id: string;
  label: string;
};

type ProductMode = "all" | "cosplay" | "figura";

function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

const db = Astro.locals.runtime.env.DB as any;

const universoId = Astro.url.searchParams.get("universoId");
const origenId = Astro.url.searchParams.get("origenId");
const tipoProductoParam = Astro.url.searchParams.get("tipoProducto");

const productMode: ProductMode =
  tipoProductoParam === "cosplay"
    ? "cosplay"
    : tipoProductoParam === "figura"
      ? "figura"
      : "all";

let categories: CategoryCard[] = [];
let universos: UniverseCard[] = [];
let origins: OriginItem[] = [];

let universoNombre: string | null = null;
let origenNombre: string | null = null;

const buildExploreUrl = (next: {
  universoId?: string | null;
  origenId?: string | null;
  tipoProducto?: ProductMode | null;
}) => {
  const params = new URLSearchParams();

  if (next.universoId) params.set("universoId", next.universoId);
  if (next.origenId) params.set("origenId", next.origenId);
  if (next.tipoProducto && next.tipoProducto !== "all") {
    params.set("tipoProducto", next.tipoProducto);
  }

  const query = params.toString();
  return `/explorar${query ? `?${query}` : ""}`;
};

const nextProductMode: ProductMode =
  productMode === "all"
    ? "cosplay"
    : productMode === "cosplay"
      ? "figura"
      : "all";

const productModeToggleHref = buildExploreUrl({
  universoId,
  origenId,
  tipoProducto: nextProductMode,
});

const clearFilterHref =
  universoId || origenId || productMode !== "all" ? "/explorar" : null;

if (!db) {
  console.warn("[explorar] DB binding no disponible.");
} else {

  /* ========================= */
  /* ORIGENES                  */
  /* ========================= */

  const origenesRes = await db
    .prepare(`
      SELECT id_etiqueta, nombre_etiqueta
      FROM etiquetas
      WHERE tipo_etiqueta = 'origen'
      ORDER BY nombre_etiqueta ASC
    `)
    .all();

  const origenRows = (origenesRes?.results || []) as EtiquetaRow[];

  origins = origenRows.map((o) => ({
    id: String(o.id_etiqueta),
    label: o.nombre_etiqueta,
  }));

  /* ========================= */
  /* UNIVERSOS                 */
  /* ========================= */

  const universosRes = await db
    .prepare(`
      SELECT id_universo, nombre_universo, img_universo
      FROM universos
      ORDER BY nombre_universo ASC
    `)
    .all();

  const universosRows = (universosRes?.results || []) as UniversoRow[];

  universos = universosRows.map((u) => ({
    id: String(u.id_universo),
    title: u.nombre_universo,
    imageUrl: u.img_universo ?? null,
  }));

  if (universoId) {
    const universoRes = await db
      .prepare(`
        SELECT nombre_universo
        FROM universos
        WHERE id_universo = ?
        LIMIT 1
      `)
      .bind(universoId)
      .first();

    universoNombre = (universoRes as UniversoRow | null)?.nombre_universo ?? null;
  }

  if (origenId) {
    const origenRes = await db
      .prepare(`
        SELECT nombre_etiqueta
        FROM etiquetas
        WHERE id_etiqueta = ?
        LIMIT 1
      `)
      .bind(origenId)
      .first();

    origenNombre = (origenRes as EtiquetaRow | null)?.nombre_etiqueta ?? null;
  }

  /* ========================= */
  /* PERSONAJES                */
  /* ========================= */

  let sql = `
    SELECT
      p.id_personaje,
      p.nombre_personaje,
      p.id_universo,

      (
  SELECT json_group_array(
    json_object(
      'url',
      url
    )
  )
  FROM (
    SELECT url
    FROM personajes_imagenes
    WHERE id_personaje = p.id_personaje
    ORDER BY es_principal DESC, orden ASC
  )
) AS gallery,

      COUNT(DISTINCT pr.id_producto) AS productsCount

    FROM personajes p
    LEFT JOIN productos pr
      ON pr.id_personaje = p.id_personaje
  `;

  const whereClauses: string[] = [];
  const params: any[] = [];

  if (origenId) {
    sql += `
      INNER JOIN personajes_etiquetas pe
        ON pe.id_personaje = p.id_personaje
    `;
    whereClauses.push(`pe.id_etiqueta = ?`);
    params.push(origenId);
  }

  if (universoId) {
    whereClauses.push(`p.id_universo = ?`);
    params.push(universoId);
  }

  if (productMode === "cosplay") {
    whereClauses.push(`
      EXISTS (
        SELECT 1
        FROM productos prc
        WHERE prc.id_personaje = p.id_personaje
          AND CAST(COALESCE(prc.tipo_cosplay,'0') AS TEXT) = '1'
      )
    `);
  }

  if (productMode === "figura") {
    whereClauses.push(`
      EXISTS (
        SELECT 1
        FROM productos prf
        WHERE prf.id_personaje = p.id_personaje
          AND CAST(COALESCE(prf.tipo_cosplay,'0') AS TEXT) <> '1'
      )
    `);
  }

  if (whereClauses.length) {
    sql += ` WHERE ${whereClauses.join(" AND ")} `;
  }

  sql += `
    GROUP BY p.id_personaje
    ORDER BY p.nombre_personaje ASC
  `;

  const personajesRes = params.length
    ? await db.prepare(sql).bind(...params).all()
    : await db.prepare(sql).all();

  const personajes = (personajesRes?.results || []) as PersonajeRow[];

  categories = personajes.map((p) => ({
    meta: {
      id_personaje: p.id_personaje,
      title: p.nombre_personaje,
      slug: slugify(p.nombre_personaje),

      gallery: (() => {
        try {
          return p.gallery ? JSON.parse(p.gallery as any) : [];
        } catch {
          return [];
        }
      })(),
    },
    productsCount: Number((p as any).productsCount || 0),
  }));
}

const meta = {
  title: origenNombre
    ? `Explorar: ${origenNombre}`
    : universoNombre
      ? `Explorar: ${universoNombre}`
      : "Explorar Personajes",
};
---

<Layout title={`${meta.title} | 3D Shop`}>
  <NewPageWrapper
    client:load
    meta={meta}
    categories={categories}
    universes={universos}
    origins={origins}
    activeOrigenId={origenId}
    activeUniversoId={universoId}
    clearFilterHref={clearFilterHref}
    origenNombre={origenNombre}
    productMode={productMode}
    productModeToggleHref={productModeToggleHref}
  />
</Layout>