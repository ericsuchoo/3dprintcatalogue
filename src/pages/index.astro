---
export const prerender = false;

import type {
    HomeEntry,
    ProductCategoryEntryMetaItem,
    ProductEntry,
} from '../../bcms/types/ts';
import { productToLite } from '../utils/product';
import Layout from '../layouts/Layout.astro';
import HomePageWrapper from '../components/home-page/PageWrapper';
import { bcmsPrivate } from '../bcms-private';
import { bcmsPublic } from '../bcms-public';

// 1. Datos de BCMS
const home = (await bcmsPrivate.entry.getById('home', 'home')) as HomeEntry;
const homeMeta = home.meta.en as any;
const products = (await bcmsPrivate.entry.getAll('product')) as ProductEntry[];
const productsLite = products.map((e) => productToLite(e));

// 2. OBTENER DATOS DE CLOUDFLARE D1 (DINÁMICO)
const runtime = (Astro.locals as any).runtime;
let universosDB: any[] = [];

if (runtime?.env?.DB) {
    try {
        // Consultamos tu tabla real en la nube
        const { results } = await runtime.env.DB.prepare("SELECT * FROM universos").all();
        universosDB = results;
    } catch (e) {
        console.error("D1 Production Error:", e);
    }
}

// 3. MAPEAR CATEGORÍAS BASADO EN D1
const categories = universosDB.map((uni: any) => {
    const productsInUniverso = products.filter((p: any) => {
        const brandTitle = p.meta?.en?.brand?.meta?.en?.title;
        const hasCategory = p.meta?.en?.categories?.some((cat: any) => 
            cat.meta?.en?.title === uni.nombre_universo
        );
        return brandTitle === uni.nombre_universo || hasCategory;
    });

    return {
        meta: {
            title: uni.nombre_universo,
            slug: uni.nombre_universo.toLowerCase().trim().replace(/\s+/g, '-'),
            gallery: [{
                src: uni.img_universo, // URL de R2 desde tu D1
                alt: uni.nombre_universo,
                _id: `d1_${uni.id_universo}`,
                name: uni.nombre_universo,
                extension: "webp", 
                width: 1000, 
                height: 1000,
            }]
        },
        productsCount: productsInUniverso.length,
    };
});

// 4. Filtros Dinámicos
const filters = {
    categories: products.reduce((acc, e) => {
        e.meta.en?.categories.forEach((i: any) => {
            if (i.meta?.en && !acc.find((c: any) => c.slug === i.meta.en?.slug)) {
                acc.push(i.meta.en);
            }
        });
        return acc;
    }, [] as ProductCategoryEntryMetaItem[]),
    genders: universosDB.map((uni: any) => ({
        title: uni.nombre_universo,
        slug: uni.nombre_universo.toLowerCase().trim().replace(/\s+/g, '-')
    })),
};

const clientConfig = bcmsPublic.getConfig();
---
<Layout title={`${homeMeta?.seo?.title || homeMeta?.title} | 3D Shop`}>
    <HomePageWrapper
        client:load
        bcms={clientConfig}
        meta={homeMeta}
        categories={categories as any}
        products={productsLite}
        filters={filters}
        logo_dc3={homeMeta.logo_dc3 || homeMeta.hero_logo} 
    />
</Layout>