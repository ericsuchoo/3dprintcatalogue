---
export const prerender = false;

type Producto = {
  id_producto: number;
  nombre_producto: string | null;
  precio: number | null;
  img_producto: string | null;
};

const res = await fetch(new URL("/api/productos", Astro.url));

if (!res.ok) {
  const text = await res.text().catch(() => "");
  throw new Error(`Error /api/productos: ${res.status} ${res.statusText} ${text}`);
}

const productos = (await res.json()) as Producto[];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Test Productos</title>
    <style>
      body { font-family: system-ui, sans-serif; padding: 16px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
      .card { background: #1e1e1e; color: white; padding: 12px; border-radius: 12px; }
      img { width: 100%; border-radius: 10px; display: block; }
      .price { font-weight: 700; margin-top: 8px; }
      a { color: #4ea1ff; }
    </style>
  </head>

  <body>
    <h1>Productos desde D1 (Preview)</h1>
    <p>Fuente: <a href="/api/productos">/api/productos</a></p>

    {productos.length === 0 ? (
      <p>No hay productos.</p>
    ) : (
      <div class="grid">
        {productos.map((p: Producto) => (
          <div class="card">
            {p.img_producto ? <img src={p.img_producto} alt={p.nombre_producto ?? "Producto"} /> : null}
            <h2>{p.nombre_producto ?? "Sin nombre"}</h2>
            <div class="price">{p.precio ?? "—"}</div>
          </div>
        ))}
      </div>
    )}
  </body>
</html>