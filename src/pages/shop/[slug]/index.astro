---
import Layout from "../../../layouts/Layout.astro";
import ProductPageWrapper from "../../../components/shop/product/PageWrapper";

type ProductoRow = {
  id_producto: number;
  nombre_producto: string;
  subtitulo?: string | null;
  descripcion?: string | null;
  img_producto?: string | null;
  unidades?: number | null;
  precio?: number | null;
  descuento?: number | null;
  id_proveedor?: number | null;
  id_universo?: number | null;
  id_personaje?: number | null;
  fecha_creacion?: string | null;
  fecha_modifica?: string | null;
  disclaimer?: string | null;
  aspectos_variables?: string | null;
  tipo_cosplay?: string | null;
};

type EscalaRow = {
  id_producto: number;
  disponible: number | null;
  id_escala: number;
  nombre_escala: string;
  descripcion?: string | null;
};

function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB as any;

if (!db) return Astro.redirect("/404");

// 🔥 CONTROL NSFW (luego lo puedes hacer dinámico)
const mostrarNSFW = false;

// 1) Resolver slug
const listRes = await db.prepare(`SELECT id_producto, nombre_producto FROM productos`).all();
const list = (listRes?.results || []) as any[];

const found = list.find((p) => slugify(p.nombre_producto) === slug);
if (!found) return Astro.redirect("/404");

// 2) Producto
const product = await db
  .prepare(`SELECT * FROM productos WHERE id_producto = ? LIMIT 1`)
  .bind(found.id_producto)
  .first();

if (!product) return Astro.redirect("/404");

// 3) 🔥 EDICIONES + IMÁGENES (PRO)
const edRes = await db
  .prepare(`
    SELECT
      ep.id_edicion_producto,
      ep.id_edicion,
      e.nombre_edicion,
      ei.img_url,
      ei.orden,
      ei.nivel_contenido
    FROM edicion_producto ep
    INNER JOIN ediciones e ON e.id_edicion = ep.id_edicion
    LEFT JOIN edicion_imagenes ei 
      ON ei.id_edicion_producto = ep.id_edicion_producto
    WHERE ep.id_producto = ?
    ORDER BY ep.id_edicion_producto ASC, ei.orden ASC
  `)
  .bind(product.id_producto)
  .all();

const rows = (edRes?.results || []) as any[];

const map = new Map<number, any>();

for (const row of rows) {
  if (!map.has(row.id_edicion_producto)) {
    map.set(row.id_edicion_producto, {
      id_edicion: row.id_edicion,
      nombre_edicion: row.nombre_edicion,
      images: [],
    });
  }

  if (row.img_url) {
    map.get(row.id_edicion_producto).images.push({
      url: row.img_url,
      nivel: row.nivel_contenido || "safe",
      orden: row.orden || 0, // 🔥 necesario para ordenar
    });
  }
}

// 🔥 FORMATO FINAL (FUERA DEL FOR)
const editions = Array.from(map.values()).map((ed) => {
  // ordenar por orden
  ed.images.sort((a: any, b: any) => a.orden - b.orden);

  // portada inteligente
  const safeImage = ed.images.find((img: any) => img.nivel !== "nsfw")?.url;
  const firstImage = ed.images[0]?.url || null;

  return {
    id_edicion: ed.id_edicion,
    nombre_edicion: ed.nombre_edicion,
    img: safeImage || firstImage || product.img_producto || null,

    // 🔥 AQUÍ ESTÁ LA CLAVE (NO BORRAR nivel)
    images: ed.images.map((img: any) => ({
      url: img.url,
      nivel: img.nivel, // 🔥 ESTA LÍNEA ES LA QUE TE FALTABA
    })),
  };
});

// 4) Escalas
const scalesRes = await db
  .prepare(`
    SELECT
      ep.id_producto,
      ep.disponible,
      es.id_escala,
      es.nombre_escala,
      es.descripcion
    FROM escala_producto ep
    INNER JOIN escalas es ON es.id_escala = ep.id_escala
    WHERE ep.id_producto = ?
    ORDER BY es.id_escala ASC
  `)
  .bind(product.id_producto)
  .all();

const scales = (scalesRes?.results || []).map((row: any) => ({
  id_escala: row.id_escala,
  nombre_escala: row.nombre_escala,
  descripcion: row.descripcion ?? "",
  disponible: Number(row.disponible || 0) === 1,
}));

// 5) Relacionados (igual)
let relatedRows: any[] = [];

if (product.id_personaje) {
  const rel = await db
    .prepare(`
      SELECT * FROM productos
      WHERE id_producto != ?
      AND id_personaje = ?
      LIMIT 8
    `)
    .bind(product.id_producto, product.id_personaje)
    .all();

  relatedRows = rel?.results || [];
}

// FINAL
const data = {
  meta: {
    id_producto: product.id_producto,
    title: product.nombre_producto,
    slug: slugify(product.nombre_producto),
    model_id: slugify(product.nombre_producto).toUpperCase(),
    subtitle: product.subtitulo ?? "",
    price: product.precio ?? 0,
    descuento: product.descuento ?? null,
    descripcion: product.descripcion ?? "",
    description: product.descripcion ?? "",
    disclaimer: product.disclaimer ?? "",
    aspectos_variables: product.aspectos_variables ?? "",
    tipo_cosplay: product.tipo_cosplay ?? "",
    personajeId: product.id_personaje ?? null,
    universoId: product.id_universo ?? null,
    proveedorId: product.id_proveedor ?? null,
    cover: product.img_producto ? { url: product.img_producto } : null,
    editions,
    scales,
  },

  otherProducts: relatedRows.map((pr) => ({
    id: pr.id_producto,
    slug: slugify(pr.nombre_producto),
    title: pr.nombre_producto,
    subtitle: pr.subtitulo ?? "",
    description: pr.descripcion ?? "",
    price: pr.precio ?? 0,
    discount: pr.descuento ?? 0,
    units: pr.unidades ?? null,
    coverUrl: pr.img_producto ?? "",
  })),
};
---

<Layout title={`${data.meta.title} | DCimpress 3D`}>
  <ProductPageWrapper client:load data={data as any} />
</Layout>