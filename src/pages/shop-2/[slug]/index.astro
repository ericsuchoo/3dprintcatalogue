---
import type { ProductEntry, ProductEntryMetaItem } from "../../../../bcms/types/ts";
import { productToLite } from "../../../utils/product";

import Layout from "../../../layouts/Layout.astro";
import ProductPageWrapper from "../../../components/shop/product/PageWrapper";

import { getBcmsPrivateBuild } from "../../../bcms-private";
import { getBcmsPublicBuild } from "../../../bcms-public";

// ✅ Cliente BCMS para BUILD (porque usamos getStaticPaths)
const bcmsPrivate = getBcmsPrivateBuild();
const bcmsPublic = getBcmsPublicBuild();
const clientConfig = bcmsPublic.getConfig();

export async function getStaticPaths() {
  const products = (await bcmsPrivate.entry.getAll("product")) as ProductEntry[];

  return products.map((e) => ({
    params: { slug: e.meta.en?.slug || "" },
  }));
}

const { slug } = Astro.params;

const products = (await bcmsPrivate.entry.getAll("product")) as ProductEntry[];
const entry = products.find((e) => e.meta.en?.slug === slug);

if (!entry?.meta?.en) return Astro.redirect("/404");

const meta = entry.meta.en as ProductEntryMetaItem;

const data = {
  meta,
  otherProducts: products
    .filter((e) => e.meta.en?.slug !== slug)
    .map((e) => productToLite(e))
    .sort((a, b) => b.date - a.date)
    .slice(0, 4),
};
---

<Layout title={`${meta.title} - Premium`}>
  <ProductPageWrapper client:load data={data as any} />
</Layout>