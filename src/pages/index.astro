---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import HomePageWrapper from "../components/home-page/PageWrapper";
import { homeStaticData } from "../data/home";

// ✅ D1
const db = Astro.locals.runtime.env.DB;

// --------------------
// ORÍGENES
// --------------------
type EtiquetaRow = {
  id_etiqueta: string;
  nombre_etiqueta: string;
  tipo_etiqueta: string;
};

const etiquetasRes = await db
  .prepare(`
    SELECT id_etiqueta, nombre_etiqueta, tipo_etiqueta
    FROM etiquetas
    WHERE tipo_etiqueta = ?
    ORDER BY nombre_etiqueta ASC
  `)
  .bind("origen")
  .all();

const etiquetas = etiquetasRes as { results: EtiquetaRow[] };

const origins = (etiquetas.results || []).map((e: EtiquetaRow) => ({
  id: e.id_etiqueta,
  label: e.nombre_etiqueta,
}));

// --------------------
// UNIVERSOS + CONTEO DE PERSONAJES
// --------------------
type UniversoCardRow = {
  id_universo: number;
  nombre_universo: string;
  img_universo: string | null;
  personajesCount: number;
};

const universosAggRes = await db
  .prepare(`
    SELECT
      u.id_universo,
      u.nombre_universo,
      u.img_universo,
      COALESCE(COUNT(p.id_personaje), 0) AS personajesCount
    FROM universos u
    LEFT JOIN personajes p
      ON p.id_universo = u.id_universo
    GROUP BY u.id_universo
    ORDER BY u.nombre_universo ASC
  `)
  .all();

const universosAgg = universosAggRes.results as unknown as UniversoCardRow[];

const toSlug = (s: string) =>
  s
    .toLowerCase()
    .trim()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");

const categories = (universosAgg || []).map((u) => ({
  meta: {
    id_universo: u.id_universo,
    title: u.nombre_universo,
    slug: toSlug(u.nombre_universo),
    gallery: u.img_universo ? [{ url: u.img_universo }] : [],
  },
  productsCount: u.personajesCount,
}));
---

<Layout title={`${homeStaticData.seo?.title || homeStaticData.title} | 3D Shop`}>

  <HomePageWrapper
    client:load
   
    meta={homeStaticData as any}
    categories={categories}
    origins={origins}
  />
</Layout>