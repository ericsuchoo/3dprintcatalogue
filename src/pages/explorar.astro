---
import Layout from "../layouts/Layout.astro";
import NewPageWrapper from "../components/home-page/PageWrapperfil";

type PersonajeRow = {
  id_personaje: number | string;
  nombre_personaje: string;
  img_personaje: string | null;
  id_universo?: number | null;
  productsCount?: number;
};

type CategoryCard = {
  meta: { title: string; slug: string; gallery: { url: string }[] };
  productsCount: number;
};

function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

const db = Astro.locals.runtime.env.DB as any;

// ✅ lee filtro del universo (si viene)
const universoId = Astro.url.searchParams.get("universoId");

// ✅ botón para limpiar filtro
const clearFilterHref = universoId ? "/explorar" : null;

// ✅ categories tipado desde el inicio (sin any)
let categories: CategoryCard[] = [];

if (!db) {
  console.warn("[explorar] DB binding no disponible.");
} else {
  // OJO: si filtras por universoId:
  const sql = `
    SELECT
      p.id_personaje,
      p.nombre_personaje,
      p.img_personaje,
      p.id_universo,
      COUNT(pr.id_producto) AS productsCount
    FROM personajes p
    LEFT JOIN productos pr ON pr.id_personaje = p.id_personaje
    ${universoId ? "WHERE p.id_universo = ?" : ""}
    GROUP BY p.id_personaje
    ORDER BY p.nombre_personaje ASC
  `;

  const personajesRes = universoId
    ? await db.prepare(sql).bind(universoId).all()
    : await db.prepare(sql).all();

  const personajes = (personajesRes?.results || []) as PersonajeRow[];

  categories = personajes.map((p) => ({
    meta: {
      title: p.nombre_personaje,
      slug: slugify(p.nombre_personaje),
      gallery: p.img_personaje ? [{ url: p.img_personaje }] : [],
    },
    productsCount: Number((p as any).productsCount || 0),
  }));
}

const meta = { title: "Explorar Personajes" };
---

<Layout title="Explorar Personajes | 3D Shop">
  <NewPageWrapper
    client:load
    meta={meta}
    categories={categories}
    clearFilterHref={clearFilterHref}
  />
</Layout>