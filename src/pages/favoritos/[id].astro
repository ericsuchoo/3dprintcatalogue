---
import Layout from "../../layouts/Layout.astro";
import ProductsPageWrapper from "../../components/shop/products/PageWrapper";

type ProductoRow = {
  id_producto: number | string;
  nombre_producto: string;
  subtitulo?: string | null;
  descripcion?: string | null;
  img_producto?: string | null;
  unidades?: number | null;
  precio?: number | null;
  descuento?: number | null;
  id_proveedor?: number | null;
  id_universo?: number | null;
  id_personaje?: number | null;
  fecha_creacion?: string | null;
  fecha_modifica?: string | null;
};

function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

const db = Astro.locals.runtime.env.DB as any;
const shareId = Astro.params.id;

let productos: ProductoRow[] = [];
let listaExiste = false;

if (db && shareId) {
  const shareRow = await db
    .prepare(`
      SELECT id_compartido
      FROM favoritos_compartidos
      WHERE id_compartido = ?
      LIMIT 1
    `)
    .bind(shareId)
    .first();

  listaExiste = Boolean(shareRow?.id_compartido);

  if (listaExiste) {
    const res = await db
      .prepare(`
        SELECT
          p.id_producto,
          p.nombre_producto,
          p.subtitulo,
          p.descripcion,
          p.img_producto,
          p.unidades,
          p.precio,
          p.descuento,
          p.id_proveedor,
          p.id_universo,
          p.id_personaje,
          p.fecha_creacion,
          p.fecha_modifica
        FROM favoritos_compartidos_items f
        JOIN productos p ON p.id_producto = f.id_producto
        WHERE f.id_compartido = ?
        ORDER BY p.nombre_producto ASC
      `)
      .bind(shareId)
      .all();

    productos = (res?.results || []) as ProductoRow[];
  }
}

const data = {
  products: productos.map((p) => ({
    id: p.id_producto,
    slug: slugify(p.nombre_producto),
    title: p.nombre_producto,
    subtitle: p.subtitulo ?? "",
    description: p.descripcion ?? "",
    price: p.precio ?? 0,
    discount: p.descuento ?? 0,
    units: p.unidades ?? null,
    coverUrl: p.img_producto ?? "",
    personajeId: p.id_personaje ?? null,
    universoId: p.id_universo ?? null,
    proveedorId: p.id_proveedor ?? null,
    date: p.fecha_modifica ?? p.fecha_creacion ?? null,
  })),

  genders: [],
  categories: [],
  brands: [],

  initialPersonajeId: null,
  initialUniversoId: null,
  initialProveedorId: null,
  initialSort: "newest" as const,

  personajeNombre: null,
  universoNombre: null,
  proveedorNombre: null,
  activeFilterLabels: ["Lista compartida"],

  selectedCharacter: null,
  quickCharacterSuggestions: [],

  clearFilterHref: "/shop",

  pagination: {
    currentPage: 1,
    totalPages: 1,
    totalProducts: productos.length,
    itemsPerPage: productos.length || 1,
    pageCount: productos.length,
    basePath: `/favoritos/${shareId}`,
    personajeId: null,
    universoId: null,
    proveedorId: null,
    sort: "newest" as const,
  },
};
---

<Layout title="Lista compartida | DCimpress 3D">
  <div class="bg-[#0a0a0a] min-h-screen px-4 md:px-6 pt-24 md:pt-28 pb-8">
    <div class="max-w-6xl mx-auto mb-10 border border-[#00eeff] bg-[#0f0f0f] rounded-xl p-6 md:p-8 backdrop-blur">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <h1 class="text-3xl md:text-4xl font-black uppercase italic text-white tracking-tight">
            Lista compartida
          </h1>

          <p class="text-xs md:text-sm text-zinc-500 uppercase tracking-[0.18em] mt-2 font-bold">
            {productos.length} producto{productos.length === 1 ? "" : "s"}
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <button
            onclick="navigator.clipboard.writeText(window.location.href)"
            class="px-4 py-2 rounded-full border border-white/20 text-white text-xs uppercase tracking-widest hover:border-red-500 hover:text-red-400 transition"
          >
            Copiar enlace
          </button>

          <a
            href="/shop"
            class="px-4 py-2 rounded-full border border-red-500/40 text-red-400 text-xs uppercase tracking-widest hover:bg-red-500/10 transition"
          >
            Ir al catálogo
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-6xl mx-auto">
      {
        !listaExiste ? (
          <div class="rounded-2xl border border-white/10 bg-[#0f0f0f] px-6 py-12 text-center">
            <div class="text-xl md:text-2xl font-black uppercase italic text-white">
              Lista no encontrada
            </div>
            <p class="text-zinc-400 mt-3 max-w-2xl mx-auto">
              El enlace compartido no existe o ya no está disponible.
            </p>
          </div>
        ) : productos.length === 0 ? (
          <div class="rounded-2xl border border-white/10 bg-[#0f0f0f] px-6 py-12 text-center">
            <div class="text-xl md:text-2xl font-black uppercase italic text-white">
              Lista vacía
            </div>
            <p class="text-zinc-400 mt-3 max-w-2xl mx-auto">
              Esta lista compartida no contiene productos.
            </p>
          </div>
        ) : (
          <ProductsPageWrapper client:load data={data} />
        )
      }
    </div>
  </div>
</Layout>