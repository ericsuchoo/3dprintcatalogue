---
interface Producto {
  id_producto: number;
  nombre_producto: string | null;
  precio: number | null;
  img_producto: string | null;
}

const res = await fetch(new URL('/api/productos', Astro.url));
const productos: Producto[] = await res.json();
---

<h1>Productos desde D1 (Preview)</h1>

{productos.length === 0 && <p>No hay productos.</p>}

<div class="grid">
  {productos.map((p) => (
    <div class="card">
      {p.img_producto && (
        <img src={p.img_producto} alt={p.nombre_producto ?? ""} />
      )}
      <h2>{p.nombre_producto}</h2>
      <p>${p.precio}</p>
    </div>
  ))}
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }
  .card {
    background: #1e1e1e;
    padding: 20px;
    border-radius: 10px;
  }
  img {
    width: 100%;
    border-radius: 8px;
  }
</style>