---
import Layout from "../../layouts/Layout.astro";
import ProductsPageWrapper from "../../components/shop/products/PageWrapper";

// --------------------
// Tipos D1
// --------------------
type ProductoRow = {
  id_producto: number | string;
  nombre_producto: string;
  subtitulo?: string | null;
  descripcion?: string | null;
  img_producto?: string | null;
  unidades?: number | null;
  precio?: number | null;
  descuento?: number | null;
  id_proveedor?: number | null;
  id_universo?: number | null;
  id_personaje?: number | null;
  fecha_creacion?: string | null;
  fecha_modifica?: string | null;
};

type PersonajeRow = {
  id_personaje: number | string;
  nombre_personaje: string;
};

type UniversoRow = {
  id_universo: number | string;
  nombre_universo: string;
};

type ProveedorRow = {
  id_proveedor: number | string;
  nombre_proveedor: string;
};

function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

function parsePositiveInt(value: string | null) {
  if (!value) return null;
  const num = Number(value);
  if (!Number.isInteger(num) || num <= 0) return null;
  return num;
}

function normalizeSort(value: string | null) {
  const allowed = ["newest", "price_asc", "price_desc"] as const;
  if (value && allowed.includes(value as any)) return value as (typeof allowed)[number];
  return "newest";
}

const db = Astro.locals.runtime.env.DB as any;

// --------------------
// Query params
// --------------------
const personajeId = parsePositiveInt(Astro.url.searchParams.get("personajeId"));
const universoId = parsePositiveInt(Astro.url.searchParams.get("universoId"));
const proveedorId = parsePositiveInt(Astro.url.searchParams.get("proveedorId"));
const requestedPage = parsePositiveInt(Astro.url.searchParams.get("page")) ?? 1;
const sort = normalizeSort(Astro.url.searchParams.get("sort"));

const ITEMS_PER_PAGE = 30;

let personajeNombre: string | null = null;
let universoNombre: string | null = null;
let proveedorNombre: string | null = null;

if (!db) {
  console.warn("[shop] DB binding no disponible. Revisa wrangler.toml/bindings.");
}

async function tableExists(name: string) {
  if (!db) return false;
  const row = await db
    .prepare(`SELECT name FROM sqlite_master WHERE type='table' AND name = ?`)
    .bind(name)
    .first();
  return !!row?.name;
}

// --------------------
// 0) Resolver nombres activos
// --------------------
if (db && personajeId) {
  const row = await db
    .prepare(`
      SELECT id_personaje, nombre_personaje
      FROM personajes
      WHERE id_personaje = ?
      LIMIT 1
    `)
    .bind(personajeId)
    .first();

  personajeNombre = (row as PersonajeRow | null)?.nombre_personaje ?? null;
}

if (db && universoId) {
  const row = await db
    .prepare(`
      SELECT id_universo, nombre_universo
      FROM universos
      WHERE id_universo = ?
      LIMIT 1
    `)
    .bind(universoId)
    .first();

  universoNombre = (row as UniversoRow | null)?.nombre_universo ?? null;
}

if (db && proveedorId && (await tableExists("proveedores"))) {
  const row = await db
    .prepare(`
      SELECT id_proveedor, nombre_proveedor
      FROM proveedores
      WHERE id_proveedor = ?
      LIMIT 1
    `)
    .bind(proveedorId)
    .first();

  proveedorNombre = (row as ProveedorRow | null)?.nombre_proveedor ?? null;
}

// --------------------
// 1) WHERE dinámico
// --------------------
const whereClauses: string[] = [];
const whereParams: any[] = [];

if (personajeId) {
  whereClauses.push(`id_personaje = ?`);
  whereParams.push(personajeId);
}

if (universoId) {
  whereClauses.push(`id_universo = ?`);
  whereParams.push(universoId);
}

if (proveedorId) {
  whereClauses.push(`id_proveedor = ?`);
  whereParams.push(proveedorId);
}

const whereSql = whereClauses.length ? `WHERE ${whereClauses.join(" AND ")}` : "";

// --------------------
// 2) ORDER dinámico
// --------------------
let orderSql = `ORDER BY COALESCE(fecha_modifica, fecha_creacion) DESC, id_producto DESC`;

if (sort === "price_asc") {
  orderSql = `ORDER BY COALESCE(precio, 0) ASC, id_producto DESC`;
} else if (sort === "price_desc") {
  orderSql = `ORDER BY COALESCE(precio, 0) DESC, id_producto DESC`;
}

// --------------------
// 3) Conteo real
// --------------------
let totalProducts = 0;

if (db) {
  const countSql = `
    SELECT COUNT(*) as total
    FROM productos
    ${whereSql}
  `;

  const countRes = whereParams.length
    ? await db.prepare(countSql).bind(...whereParams).first()
    : await db.prepare(countSql).first();

  totalProducts = Number((countRes as any)?.total || 0);
}

const totalPages = Math.max(1, Math.ceil(totalProducts / ITEMS_PER_PAGE));
const currentPage = Math.min(requestedPage, totalPages);
const offset = (currentPage - 1) * ITEMS_PER_PAGE;

// --------------------
// 4) Productos paginados
// --------------------
let productos: ProductoRow[] = [];

if (db) {
  const sql = `
    SELECT
      id_producto,
      nombre_producto,
      subtitulo,
      descripcion,
      img_producto,
      unidades,
      precio,
      descuento,
      id_proveedor,
      id_universo,
      id_personaje,
      fecha_creacion,
      fecha_modifica
    FROM productos
    ${whereSql}
    ${orderSql}
    LIMIT ? OFFSET ?
  `;

  const params = [...whereParams, ITEMS_PER_PAGE, offset];
  const res = await db.prepare(sql).bind(...params).all();
  productos = (res?.results || []) as ProductoRow[];
}

// --------------------
// 5) Filtros D1
// --------------------
let personajes: PersonajeRow[] = [];
let universos: UniversoRow[] = [];
let proveedores: ProveedorRow[] = [];

if (db) {
  if (await tableExists("personajes")) {
    const res = await db
      .prepare(`
        SELECT id_personaje, nombre_personaje
        FROM personajes
        ORDER BY nombre_personaje ASC
      `)
      .all();
    personajes = (res?.results || []) as PersonajeRow[];
  }

  if (await tableExists("universos")) {
    const res = await db
      .prepare(`
        SELECT id_universo, nombre_universo
        FROM universos
        ORDER BY nombre_universo ASC
      `)
      .all();
    universos = (res?.results || []) as UniversoRow[];
  }

  if (await tableExists("proveedores")) {
    const res = await db
      .prepare(`
        SELECT id_proveedor, nombre_proveedor
        FROM proveedores
        ORDER BY nombre_proveedor ASC
      `)
      .all();
    proveedores = (res?.results || []) as ProveedorRow[];
  }
}

const activeFilterLabels = [personajeNombre, universoNombre, proveedorNombre].filter(Boolean);

// --------------------
// 6) Data para React
// --------------------
const data = {
  products: productos.map((pr) => ({
    id: pr.id_producto,
    slug: slugify(String(pr.nombre_producto ?? `p-${pr.id_producto}`)),
    title: pr.nombre_producto ?? `Producto ${pr.id_producto}`,
    subtitle: pr.subtitulo ?? "",
    description: pr.descripcion ?? "",
    price: pr.precio ?? 0,
    discount: pr.descuento ?? 0,
    units: pr.unidades ?? null,
    coverUrl: pr.img_producto ?? "",
    personajeId: pr.id_personaje ?? null,
    universoId: pr.id_universo ?? null,
    proveedorId: pr.id_proveedor ?? null,
    date: pr.fecha_modifica ?? pr.fecha_creacion ?? null,
  })),

  genders: personajes.map((p) => ({
    title: p.nombre_personaje,
    slug: String(p.id_personaje),
  })),

  categories: universos.map((u) => ({
    title: u.nombre_universo,
    slug: String(u.id_universo),
  })),

  brands: proveedores.map((pr) => ({
    title: pr.nombre_proveedor,
    slug: String(pr.id_proveedor),
  })),

  initialPersonajeId: personajeId ? String(personajeId) : null,
  initialUniversoId: universoId ? String(universoId) : null,
  initialProveedorId: proveedorId ? String(proveedorId) : null,
  initialSort: sort,

  personajeNombre,
  universoNombre,
  proveedorNombre,
  activeFilterLabels,

  clearFilterHref:
    personajeId || universoId || proveedorId || sort !== "newest" ? "/shop" : null,

  pagination: {
    currentPage,
    totalPages,
    totalProducts,
    itemsPerPage: ITEMS_PER_PAGE,
    pageCount: productos.length,
    basePath: "/shop",
    personajeId: personajeId ? String(personajeId) : null,
    universoId: universoId ? String(universoId) : null,
    proveedorId: proveedorId ? String(proveedorId) : null,
    sort,
  },
};
---

<Layout
  title={
    activeFilterLabels.length
      ? `Shop: ${activeFilterLabels.join(" / ")} | DCimpress 3D`
      : "Tienda | DCimpress 3D"
  }
>
  <ProductsPageWrapper client:load data={data} />
</Layout>