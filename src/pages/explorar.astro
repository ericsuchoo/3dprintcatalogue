---
import type { HomeEntry } from "../../bcms/types/ts";

import Layout from "../layouts/Layout.astro";
import NewPageWrapper from "../components/home-page/PageWrapperfil";

import { getBcmsPrivate } from "../bcms-private";
import { getBcmsPublic } from "../bcms-public";

// Tipos D1 (según tus schemas)
type PersonajeRow = {
  id_personaje: number | string;
  nombre_personaje: string;
  img_personaje: string | null;
  id_universo?: number | null;
};

type ProductoRow = {
  id_producto: number | string;
  nombre_producto: string;
  subtitulo?: string | null;
  descripcion?: string | null;
  img_producto?: string | null;
  unidades?: number | null;
  precio?: number | null;
  descuento?: number | null;
  id_proveedor?: number | null;
  id_universo?: number | null;
  id_personaje?: number | null;
  fecha_creacion?: string | null;
  fecha_modifica?: string | null;
};

// Helper slug
function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

// BCMS clients (seguimos usando clientConfig para componentes que lo necesiten)
const bcmsPrivate = getBcmsPrivate(Astro.locals.runtime.env);
const bcmsPublic = getBcmsPublic(Astro.locals.runtime.env);
const clientConfig = bcmsPublic.getConfig();

// (opcional) leer meta home del BCMS para encabezado
let homeMeta: any = { title: "Explorar Personajes" };
try {
  const home = (await bcmsPrivate.entry.getById("home", "home")) as HomeEntry;
  homeMeta = home?.meta?.en ?? { title: "Explorar Personajes" };
} catch (e) {
  // Si BCMS falla en algún entorno, no rompemos SSR
  console.warn("[explorar] No se pudo cargar meta desde BCMS. Usando fallback.");
}

// D1 binding
const db = Astro.locals.runtime.env.DB as any;

// Fallback seguro (para preview / si el binding no está)
let personajes: Array<PersonajeRow & { productsCount?: number }> = [];
let productos: ProductoRow[] = [];

if (!db) {
  console.warn("[explorar] DB binding no disponible en este entorno. Renderizando vacío.");
} else {
  // 1) Personajes + conteo de productos por personaje (SQL)
  const personajesRes = await db
    .prepare(`
      SELECT
        p.id_personaje,
        p.nombre_personaje,
        p.img_personaje,
        p.id_universo,
        COUNT(pr.id_producto) AS productsCount
      FROM personajes p
      LEFT JOIN productos pr
        ON pr.id_personaje = p.id_personaje
      GROUP BY p.id_personaje
      ORDER BY p.nombre_personaje ASC
    `)
    .all();

  personajes = (personajesRes?.results || []) as Array<PersonajeRow & { productsCount?: number }>;

  // 2) Productos (para la sección inferior HomeProducts)
  const productosRes = await db
    .prepare(`
      SELECT
        id_producto,
        nombre_producto,
        subtitulo,
        descripcion,
        img_producto,
        unidades,
        precio,
        descuento,
        id_proveedor,
        id_universo,
        id_personaje,
        fecha_creacion,
        fecha_modifica
      FROM productos
    `)
    .all();

  productos = (productosRes?.results || []) as ProductoRow[];
}

/**
 * categories: una card por personaje con meta {title, slug, gallery[]} y productsCount
 */
const categories = personajes.map((p) => {
  return {
    meta: {
      title: p.nombre_personaje,
      slug: slugify(p.nombre_personaje),
      gallery: p.img_personaje ? [{ url: p.img_personaje }] : [],
    },
    productsCount: Number((p as any).productsCount || 0),
  };
});

/**
 * productsLite: mapeo sencillo de tus productos de D1 hacia una forma útil para ProductCard.
 * Si tu ProductCard/HomeProducts espera otros campos, lo ajustamos luego.
 */
const productsLite = productos.map((pr) => {
  return {
    id: pr.id_producto,
    slug: slugify(String(pr.nombre_producto ?? `p-${pr.id_producto}`)),
    title: pr.nombre_producto ?? `Producto ${pr.id_producto}`,
    subtitle: pr.subtitulo ?? "",
    description: pr.descripcion ?? "",
    price: pr.precio ?? null,
    discount: pr.descuento ?? null,
    units: pr.unidades ?? null,
    gallery: pr.img_producto ? [{ url: pr.img_producto }] : [],
    personajeId: pr.id_personaje ?? null,
    universoId: pr.id_universo ?? null,
    providerId: pr.id_proveedor ?? null,
    createdAt: pr.fecha_creacion ?? null,
    updatedAt: pr.fecha_modifica ?? null,
  };
});

// Filtros mínimos (puedes adaptarlos más tarde)
const filters = {
  categories: [], // si más tarde quieres categories desde D1, lo añadimos
  personajes: categories.map((c) => c.meta),
};
---

<Layout title="Explorar Personajes | 3D Shop">
  <NewPageWrapper
    client:load
    bcms={clientConfig}
    meta={homeMeta}
    categories={categories as any}
    products={productsLite as any}
    filters={filters}
  />
</Layout>