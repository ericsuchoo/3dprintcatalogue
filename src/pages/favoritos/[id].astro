---
import Layout from "../../layouts/Layout.astro";
import ProductsPageWrapper from "../../components/shop/products/PageWrapper";

// --------------------
// Tipos D1
// --------------------
type ProductoRow = {
  id_producto: number | string;
  nombre_producto: string;
  subtitulo?: string | null;
  descripcion?: string | null;
  img_producto?: string | null;
  unidades?: number | null;
  precio?: number | null;
  descuento?: number | null;
  id_proveedor?: number | null;
  id_universo?: number | null;
  id_personaje?: number | null;
  fecha_creacion?: string | null;
  fecha_modifica?: string | null;
  nombre_etiqueta?: string | null;
};

function slugify(s: string) {
  return s
    .toString()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

const db = Astro.locals.runtime.env.DB as any;
const shareId = Astro.params.id;

let productos: ProductoRow[] = [];
let listaExiste = false;

if (db && shareId) {
  const shareRow = await db
    .prepare(`
      SELECT id_compartido
      FROM favoritos_compartidos
      WHERE id_compartido = ?
      LIMIT 1
    `)
    .bind(shareId)
    .first();

  listaExiste = Boolean(shareRow?.id_compartido);

  if (listaExiste) {
    const res = await db
      .prepare(`
        SELECT
          p.id_producto,
          p.nombre_producto,
          p.subtitulo,
          p.descripcion,
          p.img_producto,
          p.unidades,
          p.precio,
          p.descuento,
          p.id_proveedor,
          p.id_universo,
          p.id_personaje,
          p.fecha_creacion,
          p.fecha_modifica,
          (
            SELECT e.nombre_etiqueta
            FROM productos_etiquetas pe
            INNER JOIN etiquetas e ON e.id_etiqueta = pe.id_etiqueta
            WHERE pe.id_producto = p.id_producto
            ORDER BY
              CAST(COALESCE(pe.prioridad, e.prioridad, '9999') AS INTEGER) ASC,
              e.nombre_etiqueta ASC
            LIMIT 1
          ) as nombre_etiqueta
        FROM favoritos_compartidos_items fci
        INNER JOIN productos p
          ON p.id_producto = fci.id_producto
        WHERE fci.id_compartido = ?
        ORDER BY COALESCE(p.fecha_modifica, p.fecha_creacion) DESC, p.id_producto DESC
      `)
      .bind(shareId)
      .all();

    productos = (res?.results || []) as ProductoRow[];
  }
}

const data = {
  products: productos.map((pr) => ({
    id: pr.id_producto,
    slug: slugify(String(pr.nombre_producto ?? `p-${pr.id_producto}`)),
    title: pr.nombre_producto ?? `Producto ${pr.id_producto}`,
    subtitle: pr.subtitulo ?? "",
    description: pr.descripcion ?? "",
    price: pr.precio ?? 0,
    discount: pr.descuento ?? 0,
    units: pr.unidades ?? null,
    coverUrl: pr.img_producto ?? "",
    personajeId: pr.id_personaje ?? null,
    universoId: pr.id_universo ?? null,
    proveedorId: pr.id_proveedor ?? null,
    date: pr.fecha_modifica ?? pr.fecha_creacion ?? null,
    tagLabel: pr.nombre_etiqueta ?? "FIGURA 3D",
  })),

  genders: [],
  categories: [],
  brands: [],

  initialPersonajeId: null,
  initialUniversoId: null,
  initialProveedorId: null,
  initialSort: "newest" as const,

  personajeNombre: null,
  universoNombre: null,
  proveedorNombre: null,
  activeFilterLabels: ["Lista compartida"],

  selectedCharacter: null,
  quickCharacterSuggestions: [],

  clearFilterHref: "/shop",

  pagination: {
    currentPage: 1,
    totalPages: 1,
    totalProducts: productos.length,
    itemsPerPage: productos.length || 1,
    pageCount: productos.length,
    basePath: `/favoritos/${shareId}`,
    personajeId: null,
    universoId: null,
    proveedorId: null,
    sort: "newest" as const,
  },
};
---

<Layout title="Lista compartida | DCimpress 3D Store">
  {
    !listaExiste ? (
      <main class="bg-[#0a0a0a] min-h-screen px-4 md:px-6 pt-24 md:pt-28 pb-8">
        <div class="max-w-4xl mx-auto rounded-2xl border border-white/10 bg-[#0f0f0f] px-6 py-12 text-center">
          <div class="text-xl md:text-3xl font-black uppercase italic text-white">
            Lista no encontrada
          </div>

          <p class="text-zinc-400 mt-4 max-w-2xl mx-auto">
            El enlace compartido no existe o ya no está disponible.
          </p>

          <a
            href="/shop"
            class="inline-flex items-center justify-center mt-6 px-5 py-3 rounded-full border border-red-500/40 text-red-400 hover:text-white hover:border-red-500 transition uppercase tracking-[0.18em] font-black text-[10px] bg-red-500/10 hover:bg-red-500/20"
          >
            Ir al catálogo
          </a>
        </div>
      </main>
    ) : productos.length === 0 ? (
      <main class="bg-[#0a0a0a] min-h-screen px-4 md:px-6 pt-24 md:pt-28 pb-8">
        <div class="max-w-4xl mx-auto rounded-2xl border border-white/10 bg-[#0f0f0f] px-6 py-12 text-center">
          <div class="text-xl md:text-3xl font-black uppercase italic text-white">
            Lista vacía
          </div>

          <p class="text-zinc-400 mt-4 max-w-2xl mx-auto">
            Esta lista compartida no contiene productos.
          </p>

          <a
            href="/shop"
            class="inline-flex items-center justify-center mt-6 px-5 py-3 rounded-full border border-red-500/40 text-red-400 hover:text-white hover:border-red-500 transition uppercase tracking-[0.18em] font-black text-[10px] bg-red-500/10 hover:bg-red-500/20"
          >
            Explorar catálogo
          </a>
        </div>
      </main>
    ) : (
      <ProductsPageWrapper client:load data={data} />
    )
  }
</Layout>