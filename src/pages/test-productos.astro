---
interface Producto {
  id_producto: number;
  nombre_producto: string | null;
  subtitulo: string | null;
  descripcion: string | null;
  img_producto: string | null;
  unidades: number | null;
  precio: number | null;
  descuento: number | null;
  id_proveedor: number | null;
  id_universo: number | null;
  id_personaje: number | null;
  fecha_creacion: string | null;
  fecha_modifica: string | null;
}

const res = await fetch(new URL('/api/productos', Astro.url));
const productos: Producto[] = await res.json();
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Test Productos</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        padding: 40px;
        background: #111;
        color: white;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
      }
      .card {
        background: #1e1e1e;
        padding: 20px;
        border-radius: 10px;
      }
      img {
        width: 100%;
        border-radius: 8px;
      }
      h2 {
        margin: 10px 0 5px;
      }
      .price {
        color: #00ff9d;
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <h1>Productos desde D1 (Preview)</h1>

    {productos.length === 0 && <p>No hay productos.</p>}

    <div class="grid">
      {productos.map((p) => (
        <div class="card">
          {p.img_producto && <img src={p.img_producto} alt={p.nombre_producto ?? ""} />}
          <h2>{p.nombre_producto}</h2>
          <p>{p.subtitulo}</p>
          <p class="price">
            ${p.precio}
            {p.descuento && p.descuento > 0 && (
              <span> (-{p.descuento}%)</span>
            )}
          </p>
        </div>
      ))}
    </div>
  </body>
</html>